    {
        "id": "350768bd95b98620",
        "type": "function",
        "z": "fbdc5aeae38a6415",
        "name": "Procesar respuesta ambiente",
        "func": "// Recibe la respuesta final del ESP32 ambiental.\n// Entrada esperada desde UDP IN 5010 + nodo JSON.\n\nconst data = msg.payload;\n\nif (!data || typeof data !== \"object\") {\n    return null;\n}\n\nif (data.type !== \"environment\") {\n    return null;\n}\n\n// Guardamos la lectura final para usarla después en dibujo, SVG, G-code, etc.\nflow.set(\"last_environment\", data);\n\nif (data.state === \"done\" && data.stage === \"complete\") {\n    flow.set(\"environment_done\", true);\n\n    const response = {\n        type: \"framework_state\",\n\n        environment: true,\n        environment_done: true,\n\n        step: \"environment\",\n        state: \"done\",\n        message: \"Ambiente listo\",\n        progress: 50\n    };\n\n    // Conserva estado de foto si ya lo guardaste en el flow de foto.\n    if (flow.get(\"photo_done\") === true) {\n        response.photo = true;\n        response.photo_done = true;\n    }\n\n    msg.payload = JSON.stringify(response);\n\n    // Destino OLED\n    msg.ip = \"127.0.0.1\";\n    msg.host = \"127.0.0.1\";\n    msg.port = 5006;\n\n    return msg;\n}\n\n// Si el ESP32 respondió error\nif (data.state === \"error\") {\n    const response = {\n        type: \"status\",\n        step: \"environment\",\n        state: \"error\",\n        message: data.message || \"Error ambiente\",\n        progress: 25\n    };\n\n    msg.payload = JSON.stringify(response);\n\n    msg.ip = \"127.0.0.1\";\n    msg.host = \"127.0.0.1\";\n    msg.port = 5006;\n\n    return msg;\n}\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 680,
        "y": 700,
        "wires": [
            [
                "414875922b7d6e4e"
            ]
        ]
