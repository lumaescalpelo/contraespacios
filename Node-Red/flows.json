    {
        "id": "31956f420c1de013",
        "type": "function",
        "z": "fbdc5aeae38a6415",
        "name": "Solicitar lectura de ambiente",
        "func": "// Se activa cuando la OLED manda command == \"capture_environment\".\n// Manda una sola instrucción al ESP32 ambiental.\n\nconst toEsp32 = {\n    payload: JSON.stringify({\n        type: \"command\",\n        command: \"read_environment\",\n        source: \"node-red\",\n        target: \"contraenv\",\n        timestamp: new Date().toISOString()\n    }),\n\n    // Destino ESP32 ambiental\n    ip: \"contraenv.local\",\n    host: \"contraenv.local\",\n    port: 4210\n};\n\nreturn toEsp32;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 300,
        "y": 880,
        "wires": [
