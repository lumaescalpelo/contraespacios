    {
        "id": "f0b85a10a9aa57af",
        "type": "function",
        "z": "667a0688cf638cfb",
        "name": "To MariaDB",
        "func": "// Leer datos guardados en global\nconst sensor = global.get(\"ultimo_sensor\") || {};\nconst lugar  = global.get(\"lugar_actual\") || null;\nconst notas  = global.get(\"Notas\") || null;   // ← NUEVO\n\n// Nombre de foto: preferimos msg.foto_nombre, si no existe usamos global o null\nconst fotoNombre = msg.foto_nombre || global.get(\"foto_nombre\") || null;\n\n// Dispositivo (ajústalo a tu gusto)\nconst dispositivo = \"esp32-aire-01\";\n\n// Extraer valores (pueden ser null)\nconst temperatura = (sensor.temperatura !== undefined) ? sensor.temperatura : null;\nconst humedad     = (sensor.humedad     !== undefined) ? sensor.humedad     : null;\nconst aqi         = (sensor.aqi         !== undefined) ? sensor.aqi         : null;\nconst tvoc        = (sensor.tvoc        !== undefined) ? sensor.tvoc        : null;\nconst eco2        = (sensor.eco2        !== undefined) ? sensor.eco2        : null;\n\n// Validez: 1 si vienen todos, 0 si falta algo importante\nconst valido =\n  (temperatura !== null && humedad !== null && aqi !== null && tvoc !== null && eco2 !== null)\n    ? 1\n    : 0;\n\n// Query parametrizado para el nodo mysql\nmsg.topic = `\nINSERT INTO registros_ambiente\n(dispositivo, lugar, archivo_nombre, temperatura, humedad, aqi, tvoc, eco2, valido, notas)\nVALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n`;\n\n// Payload = array de parámetros en el orden del query\nmsg.payload = [\n  dispositivo,\n  lugar,\n  fotoNombre,\n  temperatura,\n  humedad,\n  aqi,\n  tvoc,\n  eco2,\n  valido,\n  notas           // ← NUEVO\n];\n\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1310,
        "y": 580,
        "wires": [
            [
                "c216c344d72ab192"
            ]
        ]
    },
