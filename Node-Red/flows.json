    {
        "id": "72b564eb3db0739a",
        "type": "function",
        "z": "fbdc5aeae38a6415",
        "name": "Set IMG",
        "func": "const folder = \"/home/pi/imagenes\";\n\nfunction pad(n){ return (n < 10) ? \"0\" + n : \"\" + n; }\n\nconst d = new Date();\n\n// Timestamp legible para nombre de archivo\nconst ts =\n  d.getFullYear() + \"-\" +\n  pad(d.getMonth() + 1) + \"-\" +\n  pad(d.getDate()) + \"_\" +\n  pad(d.getHours()) + \"-\" +\n  pad(d.getMinutes()) + \"-\" +\n  pad(d.getSeconds());\n\n// Guardar rutas en el mensaje\nmsg.filename = `${folder}/${ts}.jpg`;\nmsg.foto_nombre = `${ts}.jpg`;\n\n// También puedes guardar el nombre por comodidad\nglobal.set(\"foto_nombre\", msg.foto_nombre);\n\n// -----------------------\n\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 240,
        "y": 540,
        "wires": [
            [
                "b20db3363f5101dc"
            ]
        ]
