    {
        "id": "118a90ed1ccfe36e",
        "type": "function",
        "z": "fbdc5aeae38a6415",
        "name": "Respuesta pantalla",
        "func": "const response = {\n    type: \"framework_state\",\n    photo: true,\n    photo_done: true,\n    step: \"photo\",\n    state: \"done\",\n    message: \"Foto guardada\",\n    progress: 100\n};\n\nif (msg.filename) {\n    response.file = msg.filename;\n}\n\nmsg.payload = JSON.stringify(response);\n\n// Por si el nodo UDP out usa destino dinámico.\nmsg.ip = \"127.0.0.1\";\nmsg.host = \"127.0.0.1\";\nmsg.port = 5006;\n\nreturn msg;",
