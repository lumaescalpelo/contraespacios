    {
        "id": "fa9c96cb31d2381f",
        "type": "function",
        "z": "667a0688cf638cfb",
        "name": "To Int",
        "func": "// Tomar payload original\nlet p = msg.payload || {};\n\n// Crear objeto con enteros o null\nlet datos = {\n    temperatura: p.temperatura != null ? Math.round(p.temperatura) : null,\n    humedad:     p.humedad     != null ? Math.round(p.humedad)     : null,\n    aqi:         p.aqi         != null ? Math.round(p.aqi)         : null,\n    tvoc:        p.tvoc        != null ? Math.round(p.tvoc)        : null,\n    eco2:        p.eco2        != null ? Math.round(p.eco2)        : null\n};\n\n// Guardar en contexto GLOBAL\nglobal.set(\"ultimo_sensor\", datos);\n\n// No necesitamos cambiar msg.payload aquí,\n// porque este flujo solo prepara estado para después.\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
