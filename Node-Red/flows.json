        "func": "// Valor escrito por el usuario en el text input\nlet lugar = (msg.payload || \"\").toString().trim();\n\n// Si está vacío, puedes decidir:\n// - guardar null\n// - o mantener el anterior\n// Aquí guardaremos null si está vacío.\nif (lugar.length === 0) {\n    lugar = null;\n}\n\n// Guardar en contexto global\nglobal.set(\"lugar_actual\", lugar);\n\n// Pasar el mensaje sin modificar mucho\nmsg.lugar = lugar;\n\nreturn msg;\n",
